# ===========================================
# Task Dashboard - Environment Configuration
# ===========================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control

# JWT Authentication Secret (Required)
# Generate a secure key using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secure-random-key-here

# Application URL
# Change to your production domain for deployment
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# Optional: Email Service (Resend)
# ===========================================
# Enable email invitations for new users
# Get your API key from: https://resend.com
# RESEND_API_KEY=re_your_api_key_here

# ===========================================
# Optional: Supabase Database
# ===========================================
# Use cloud database instead of local JSON files
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
